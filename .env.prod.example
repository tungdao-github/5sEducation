DOMAIN=example.com
SITE_URL=https://example.com
API_URL=https://example.com

# Images
API_IMAGE=your-registry/udemyclone-api:latest
WEB_IMAGE=your-registry/udemyclone-web:latest

# Security
JWT_KEY=replace-with-strong-32-plus-char-secret

# Postgres (managed)
POSTGRES_URL=Host=YOUR_HOST;Port=5432;Database=udemyclone;Username=udemy;Password=replace-me;Ssl Mode=Require;Trust Server Certificate=true

# Seed defaults
SEED_DEFAULT_PASSWORD=ChangeMe123!
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_INSTRUCTOR_EMAIL=instructor@yourdomain.com
SEED_USER_EMAIL=user@yourdomain.com
