DOMAIN=example.com
SITE_URL=https://example.com
API_URL=/api

# Security
JWT_KEY=replace-with-strong-32-plus-char-secret
JWT_ISSUER=UdemyClone.Api
JWT_AUDIENCE=UdemyClone.Web

# Database provider: Sqlite, SqlServer, Postgres
DB_PROVIDER=Postgres
POSTGRES_DB=udemyclone
POSTGRES_USER=udemy
POSTGRES_PASSWORD=replace-me

# Postgres (managed)
POSTGRES_URL=Host=postgres;Port=5432;Database=udemyclone;Username=udemy;Password=replace-me;Include Error Detail=true

# Optional social/video integrations
GOOGLE_AUTH_CLIENT_ID=73049424474-amf71jbglk939ih4te0pg66j7tpgul9m.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=73049424474-amf71jbglk939ih4te0pg66j7tpgul9m.apps.googleusercontent.com
FACEBOOK_AUTH_APP_ID=
FACEBOOK_AUTH_APP_SECRET=
CLOUDFLARE_STREAM_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
CLOUDFLARE_STREAM_CUSTOMER_CODE=
NEXT_PUBLIC_FACEBOOK_GRAPH_VERSION=v20.0

# Seed defaults
SEED_DEFAULT_PASSWORD=ChangeMe123!
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_INSTRUCTOR_EMAIL=instructor@yourdomain.com
SEED_USER_EMAIL=user@yourdomain.com
